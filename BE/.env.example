# 复制本文件为 .env 后填写真实值
# .env 已在 .gitignore 中,不会被提交

# === 应用 ===
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# === 数据库 ===
# 默认不设 DATABASE_URL:回落到 app/config.py 用 __file__ 算的绝对路径
# (sqlite:///<BE>/data/app.db),不依赖启动目录(见 D-024)。
# 仅当需指向别处时才取消下行注释并改为【绝对路径】,勿用相对路径:
# DATABASE_URL=sqlite:////absolute/path/to/app.db

# === 通义千问(第 13 周才用,先占位)===
# 申请地址:https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=your-key-here

# === CORS ===
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
